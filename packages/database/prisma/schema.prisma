generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  REMINDER
  APPROVAL
  LMS
  REPORT
}

enum FileStatus {
  UPLOADING
  ACTIVE
  ARCHIVED
  DELETED
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  DROPPED
  EXPIRED
}

enum LessonType {
  VIDEO
  PDF
  TEXT
  QUIZ
  ASSIGNMENT
  LIVE
}

enum ReportFormat {
  PDF
  EXCEL
  CSV
  WORD
}

enum ReportSchedule {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  APPROVE
  REJECT
  UPLOAD
  DOWNLOAD
}

enum DataEntryType {
  QUANTITATIVE
  QUALITATIVE
}

enum WidgetType {
  KPI
  CHART_LINE
  CHART_BAR
  CHART_PIE
  CHART_AREA
  MAP
  TABLE
  TIMELINE
  CUSTOM
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  emailVerified     DateTime?
  passwordHash      String?
  firstName         String
  lastName          String
  phone             String?
  avatarUrl         String?
  status            UserStatus @default(PENDING_VERIFICATION)
  mfaEnabled        Boolean    @default(false)
  mfaSecret         String?
  lastLoginAt       DateTime?
  preferredLanguage String     @default("en")
  theme             String     @default("system")
  organizationId    String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  organization      Organization?      @relation(fields: [organizationId], references: [id])
  roles             UserRole[]
  sessions          Session[]
  accounts          Account[]
  refreshTokens     RefreshToken[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  dataEntries       DataEntry[]
  expenses          Expense[]          @relation("ExpenseCreator")
  approvedExpenses  Expense[]          @relation("ExpenseApprover")
  enrollments       Enrollment[]
  certificates      Certificate[]
  quizAttempts      QuizAttempt[]
  lessonProgress    LessonProgress[]
  notes             CourseNote[]
  discussions       DiscussionPost[]
  reports           Report[]
  uploadedFiles     File[]             @relation("FileUploader")
  projectMembers    ProjectMember[]
  managedProjects   Project[]          @relation("ProjectManager")
  dashboardWidgets  DashboardWidget[]
  savedFilters      SavedFilter[]
  preferences       UserPreference?
  passwordResets    PasswordReset[]
  emailVerifications EmailVerification[]

  @@index([email])
  @@index([organizationId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  module      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserPreference {
  id                 String  @id @default(cuid())
  userId             String  @unique
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  dashboardLayout    Json?
  savedViews         Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── Organizations ───────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  website     String?
  type        String?
  seats       Int      @default(10)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  enrollments  OrgEnrollment[]
  licenses     OrgLicense[]

  @@map("organizations")
}

model OrgEnrollment {
  id             String   @id @default(cuid())
  organizationId String
  courseId       String
  seats          Int      @default(1)
  enrolledAt     DateTime @default(now())
  expiresAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([organizationId, courseId])
  @@map("org_enrollments")
}

model OrgLicense {
  id             String   @id @default(cuid())
  organizationId String
  code           String   @unique
  maxUses        Int      @default(1)
  usedCount      Int      @default(0)
  expiresAt      DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_licenses")
}

// ─── Geography ─────────────────────────────────────────────────────────────────

model Province {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  latitude  Float?
  longitude Float?

  districts District[]
  projects  Project[]

  @@map("provinces")
}

model District {
  id         String  @id @default(cuid())
  name       String
  code       String  @unique
  provinceId String
  latitude   Float?
  longitude  Float?

  province Province  @relation(fields: [provinceId], references: [id])
  projects Project[]

  @@index([provinceId])
  @@map("districts")
}

// ─── Projects & M&E ────────────────────────────────────────────────────────────

model Donor {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  type        String?
  contactEmail String?
  website     String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  grants   Grant[]
  projects ProjectDonor[]

  @@map("donors")
}

model Project {
  id            String        @id @default(cuid())
  code          String        @unique
  title         String
  description   String?       @db.Text
  status        ProjectStatus @default(DRAFT)
  startDate     DateTime?
  endDate       DateTime?
  totalBudget   Decimal       @default(0) @db.Decimal(15, 2)
  currency      String        @default("PKR")
  managerId     String?
  provinceId    String?
  districtId    String?
  latitude      Float?
  longitude     Float?
  sdgTargets    String[]
  riskLevel     String?
  progressPct   Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  manager    User?           @relation("ProjectManager", fields: [managerId], references: [id])
  province   Province?       @relation(fields: [provinceId], references: [id])
  district   District?       @relation(fields: [districtId], references: [id])
  donors     ProjectDonor[]
  grants     Grant[]
  budgets    Budget[]
  expenses   Expense[]
  indicators Indicator[]
  activities Activity[]
  outputs    Output[]
  outcomes   Outcome[]
  members    ProjectMember[]
  dataEntries DataEntry[]
  files      File[]
  milestones Milestone[]

  @@index([status])
  @@index([managerId])
  @@map("projects")
}

model ProjectDonor {
  projectId String
  donorId   String
  amount    Decimal @db.Decimal(15, 2)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  donor   Donor   @relation(fields: [donorId], references: [id], onDelete: Cascade)

  @@id([projectId, donorId])
  @@map("project_donors")
}

model ProjectMember {
  projectId  String
  userId     String
  role       String   @default("member")
  joinedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

model Grant {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("PKR")
  startDate   DateTime
  endDate     DateTime
  donorId     String
  projectId   String?
  description String?  @db.Text
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  donor   Donor    @relation(fields: [donorId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  budgets Budget[]

  @@index([donorId])
  @@index([projectId])
  @@map("grants")
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime
  completedAt DateTime?
  status      String    @default("pending")
  order       Int       @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("milestones")
}

model Indicator {
  id           String   @id @default(cuid())
  projectId    String
  code         String
  title        String
  description  String?
  unit         String?
  baseline     Float    @default(0)
  target       Float
  current      Float    @default(0)
  frequency    String?
  sdgIndicator String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dataPoints  IndicatorDataPoint[]
  dataEntries DataEntry[]

  @@unique([projectId, code])
  @@index([projectId])
  @@map("indicators")
}

model IndicatorDataPoint {
  id          String   @id @default(cuid())
  indicatorId String
  value       Float
  period      String
  recordedAt  DateTime @default(now())
  notes       String?

  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@index([indicatorId])
  @@map("indicator_data_points")
}

model Activity {
  id          String   @id @default(cuid())
  projectId   String
  code        String
  title       String
  description String?  @db.Text
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("planned")
  budget      Decimal? @db.Decimal(15, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outputs Output[]

  @@unique([projectId, code])
  @@index([projectId])
  @@map("activities")
}

model Output {
  id          String   @id @default(cuid())
  projectId   String
  activityId  String?
  code        String
  title       String
  description String?
  target      Float?
  achieved    Float    @default(0)
  unit        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id])
  outcomes Outcome[]

  @@index([projectId])
  @@map("outputs")
}

model Outcome {
  id          String   @id @default(cuid())
  projectId   String
  outputId    String?
  code        String
  title       String
  description String?
  target      Float?
  achieved    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  output  Output? @relation(fields: [outputId], references: [id])

  @@index([projectId])
  @@map("outcomes")
}

model SdgIndicator {
  id          String  @id @default(cuid())
  code        String  @unique
  title       String
  goal        Int
  description String? @db.Text
  target2030  String?

  @@map("sdg_indicators")
}

// ─── Data Management ───────────────────────────────────────────────────────────

model DataEntry {
  id          String         @id @default(cuid())
  type        DataEntryType
  projectId   String?
  indicatorId String?
  title       String
  value       Json?
  narrative   String?        @db.Text
  period      String?
  status      ApprovalStatus @default(DRAFT)
  version     Int            @default(1)
  submittedBy String
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project   Project?   @relation(fields: [projectId], references: [id])
  indicator Indicator? @relation(fields: [indicatorId], references: [id])
  submitter User       @relation(fields: [submittedBy], references: [id])
  files     File[]
  history   DataEntryHistory[]

  @@index([projectId])
  @@index([status])
  @@map("data_entries")
}

model DataEntryHistory {
  id          String   @id @default(cuid())
  dataEntryId String
  version     Int
  data        Json
  changedBy   String
  changedAt   DateTime @default(now())
  changeNote  String?

  dataEntry DataEntry @relation(fields: [dataEntryId], references: [id], onDelete: Cascade)

  @@index([dataEntryId])
  @@map("data_entry_history")
}

model DataForm {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  schema      Json
  validation  Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("data_forms")
}

// ─── Finance ───────────────────────────────────────────────────────────────────

model Budget {
  id          String   @id @default(cuid())
  projectId   String
  grantId     String?
  category    String
  allocated   Decimal  @db.Decimal(15, 2)
  spent       Decimal  @default(0) @db.Decimal(15, 2)
  currency    String   @default("PKR")
  fiscalYear  String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  grant    Grant?    @relation(fields: [grantId], references: [id])
  expenses Expense[]

  @@index([projectId])
  @@map("budgets")
}

model Expense {
  id          String        @id @default(cuid())
  projectId   String
  budgetId    String?
  title       String
  description String?
  amount      Decimal       @db.Decimal(15, 2)
  currency    String        @default("PKR")
  category    String
  status      ExpenseStatus @default(DRAFT)
  receiptUrl  String?
  expenseDate DateTime
  createdBy   String
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budget   Budget? @relation(fields: [budgetId], references: [id])
  creator  User    @relation("ExpenseCreator", fields: [createdBy], references: [id])
  approver User?   @relation("ExpenseApprover", fields: [approvedBy], references: [id])

  @@index([projectId])
  @@index([status])
  @@map("expenses")
}

// ─── LMS ───────────────────────────────────────────────────────────────────────

model Course {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String?  @db.Text
  thumbnailUrl String?
  category     String?
  level        String?
  duration     Int?
  price        Decimal  @default(0) @db.Decimal(10, 2)
  currency     String   @default("PKR")
  isPublished  Boolean  @default(false)
  isFeatured   Boolean  @default(false)
  instructor   String?
  tags         String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lessons         Lesson[]
  enrollments     Enrollment[]
  orgEnrollments  OrgEnrollment[]
  quizzes         Quiz[]
  certificates    Certificate[]

  @@map("courses")
}

model Lesson {
  id          String     @id @default(cuid())
  courseId    String
  title       String
  description String?
  type        LessonType @default(TEXT)
  content     String?    @db.Text
  videoUrl    String?
  pdfUrl      String?
  duration    Int?
  order       Int        @default(0)
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
  notes    CourseNote[]
  quiz     Quiz?

  @@index([courseId])
  @@map("lessons")
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ENROLLED)
  progressPct Float            @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  expiresAt   DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@map("enrollments")
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  progressPct Float     @default(0)
  lastPosition Int      @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Quiz {
  id           String   @id @default(cuid())
  courseId     String?
  lessonId     String?  @unique
  title        String
  description  String?
  passingScore Float    @default(70)
  timeLimit    Int?
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course    Course?      @relation(fields: [courseId], references: [id])
  lesson    Lesson?      @relation(fields: [lessonId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String @id @default(cuid())
  quizId        String
  question      String @db.Text
  type          String @default("multiple_choice")
  options       Json?
  correctAnswer String
  points        Int    @default(1)
  order         Int    @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  score       Float
  passed      Boolean
  answers     Json
  startedAt   DateTime @default(now())
  completedAt DateTime?

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("quiz_attempts")
}

model Certificate {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  certificateNo  String   @unique
  issuedAt       DateTime @default(now())
  pdfUrl         String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("certificates")
}

model CourseNote {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  content   String   @db.Text
  timestamp Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@map("course_notes")
}

model DiscussionPost {
  id        String   @id @default(cuid())
  userId    String
  courseId  String?
  lessonId  String?
  parentId  String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent DiscussionPost? @relation("DiscussionReplies", fields: [parentId], references: [id])
  replies DiscussionPost[] @relation("DiscussionReplies")

  @@index([courseId])
  @@map("discussion_posts")
}

// ─── Reports ───────────────────────────────────────────────────────────────────

model Report {
  id          String         @id @default(cuid())
  title       String
  description String?
  type        String
  template    Json?
  filters     Json?
  format      ReportFormat   @default(PDF)
  schedule    ReportSchedule?
  status      ApprovalStatus @default(DRAFT)
  fileUrl     String?
  createdBy   String
  generatedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creator User @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
  @@map("reports")
}

model ReportTemplate {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  config      Json
  format      ReportFormat @default(PDF)
  isPublic    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("report_templates")
}

// ─── CMS ───────────────────────────────────────────────────────────────────────

model CmsPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  content         Json
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("cms_pages")
}

model Publication {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  abstract    String?   @db.Text
  content     String?   @db.Text
  type        String    @default("publication")
  coverUrl    String?
  fileUrl     String?
  author      String?
  publishedAt DateTime?
  tags        String[]
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("publications")
}

model CaseStudy {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  summary     String?   @db.Text
  content     String?   @db.Text
  coverUrl    String?
  projectId   String?
  location    String?
  impact      Json?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("case_studies")
}

model TeamMember {
  id        String  @id @default(cuid())
  name      String
  title     String
  bio       String? @db.Text
  photoUrl  String?
  email     String?
  linkedIn  String?
  order     Int     @default(0)
  isActive  Boolean @default(true)

  @@map("team_members")
}

model Event {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?   @db.Text
  location    String?
  startDate   DateTime
  endDate     DateTime?
  coverUrl    String?
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("events")
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String?   @db.Text
  coverUrl    String?
  author      String?
  tags        String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

model Program {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String? @db.Text
  icon        String?
  coverUrl    String?
  order       Int     @default(0)
  isActive    Boolean @default(true)

  @@map("programs")
}

// ─── Files ─────────────────────────────────────────────────────────────────────

model FileFolder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  projectId String?
  path      String
  createdAt DateTime @default(now())

  parent   FileFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children FileFolder[] @relation("FolderTree")
  files    File[]

  @@index([projectId])
  @@map("file_folders")
}

model File {
  id           String     @id @default(cuid())
  name         String
  originalName String
  mimeType     String
  size         Int
  url          String
  key          String
  folderId     String?
  projectId    String?
  dataEntryId  String?
  uploadedBy   String
  status       FileStatus @default(ACTIVE)
  version      Int        @default(1)
  movTags      String[]
  metadata     Json?
  downloadCount Int       @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  folder    FileFolder? @relation(fields: [folderId], references: [id])
  project   Project?    @relation(fields: [projectId], references: [id])
  dataEntry DataEntry?  @relation(fields: [dataEntryId], references: [id])
  uploader  User        @relation("FileUploader", fields: [uploadedBy], references: [id])
  versions  FileVersion[]

  @@index([projectId])
  @@index([uploadedBy])
  @@map("files")
}

model FileVersion {
  id        String   @id @default(cuid())
  fileId    String
  version   Int
  url       String
  key       String
  size      Int
  createdAt DateTime @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@map("file_versions")
}

// ─── Dashboard & Analytics ───────────────────────────────────────────────────────

model DashboardWidget {
  id       String     @id @default(cuid())
  userId   String?
  name     String
  type     WidgetType
  config   Json
  position Json?
  isGlobal Boolean    @default(false)
  module   String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("dashboard_widgets")
}

model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  name      String
  module    String
  filters   Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, module])
  @@map("saved_filters")
}

// ─── Notifications & Audit ─────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(INFO)
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  category  String   @default("general")
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  subject   String
  body      String   @db.Text
  variables String[]
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}
