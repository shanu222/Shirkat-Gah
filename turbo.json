{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.production", ".env.local"],
  "globalEnv": [
    "NODE_ENV",
    "NEXTAUTH_URL",
    "NEXTAUTH_SECRET",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_APP_URL"
  ],
  "tasks": {
    "generate": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXTAUTH_URL",
        "NEXTAUTH_SECRET",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_APP_URL"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@shirkat-gah/web#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@shirkat-gah/api#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@shirkat-gah/shared#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@shirkat-gah/database#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    }
  }
}
