# =============================================================================
# Vercel Production — Temporary EC2 IP deployment (no custom domain)
# Set in Vercel Dashboard → Project → Settings → Environment Variables
# =============================================================================

# Browser API base — same-origin proxy (HTTPS, no mixed content)
NEXT_PUBLIC_API_URL=/api/backend

# Server-only — direct EC2 backend (NextAuth + rewrites destination)
# MUST match the port PM2/API is listening on (verify with curl)
# NEVER expose as NEXT_PUBLIC_*
BACKEND_URL=http://13.233.16.121:4000

# NextAuth
NEXTAUTH_URL=https://shirkat-gah-web.vercel.app
NEXTAUTH_SECRET=your-64-char-secret-here

# App metadata
NEXT_PUBLIC_APP_URL=https://shirkat-gah-web.vercel.app
NEXT_PUBLIC_APP_NAME=Shirkat Gah

# Optional
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
