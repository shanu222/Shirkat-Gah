# AWS EC2 Production Environment Variables
# Copy to .env.production on EC2

NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0

DATABASE_URL=postgresql://postgres@localhost:5432/shirkat_gah?schema=public
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Vercel frontend — allow all *.vercel.app + explicit URL
CORS_ORIGINS=https://shirkat-gah-web.vercel.app
NEXT_PUBLIC_APP_URL=https://shirkat-gah-web.vercel.app

AWS_REGION=ap-south-1
S3_BUCKET=shirkat-gah-production-assets
AWS_SES_ENABLED=false
