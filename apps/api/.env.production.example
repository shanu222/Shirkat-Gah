# AWS ECS Production Environment Variables
# Stored in AWS Secrets Manager — reference only

NODE_ENV=production
API_PORT=4000
AWS_REGION=ap-south-1
AWS_SES_ENABLED=true

# From Secrets Manager (injected by ECS task definition)
# DATABASE_URL=
# REDIS_URL=
# JWT_SECRET=
# JWT_REFRESH_SECRET=

# From Terraform outputs
S3_BUCKET=
S3_REGION=ap-south-1
CDN_URL=
CORS_ORIGINS=https://app.shirkatgah.org
SES_FROM_EMAIL=noreply@shirkatgah.org

# S3_ENDPOINT — leave unset in production (uses native AWS S3 + IAM role)

SENTRY_DSN=
