aws_region            = "ap-south-1"
environment           = "production"
project_name          = "shirkat-gah"
domain_name           = "shirkatgah.org"
api_subdomain         = "api"
vercel_frontend_url   = "https://app.shirkatgah.org"
db_instance_class     = "db.t3.medium"
db_allocated_storage  = 50
redis_node_type       = "cache.t3.micro"
ecs_cpu               = 512
ecs_memory            = 1024
ecs_desired_count     = 2
