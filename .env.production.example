# =============================================================================
# Shirkat Gah — Production Environment (AWS EC2 Backend)
# Copy to .env.production on the server
# =============================================================================

NODE_ENV=production
API_PORT=3001

# Database — AWS RDS PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/shirkat_gah?schema=public&sslmode=require

# Redis — ElastiCache or local
REDIS_URL=redis://your-elasticache-endpoint:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — use strong random strings (64+ chars)
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# CORS — Vercel frontend URL
CORS_ORIGINS=https://app.shirkatgah.org,https://shirkat-gah.vercel.app
NEXT_PUBLIC_APP_URL=https://app.shirkatgah.org

# AWS S3 (leave S3_ENDPOINT empty for native AWS)
AWS_REGION=ap-south-1
S3_REGION=ap-south-1
S3_BUCKET=shirkat-gah-production-assets
S3_PUBLIC_URL=
CDN_URL=https://your-cloudfront-domain.cloudfront.net

# AWS SES
AWS_SES_ENABLED=true
SES_FROM_EMAIL=noreply@shirkatgah.org

# Monitoring
SENTRY_DSN=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
