# =============================================================================
# Shirkat Gah — Production Environment (AWS EC2 Backend)
# Copy to .env.production on the server
# =============================================================================

NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0

# Database — local PostgreSQL on EC2 or RDS
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/shirkat_gah?schema=public

# Redis — ElastiCache or local
REDIS_URL=redis://your-elasticache-endpoint:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — use strong random strings (64+ chars)
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# CORS — Vercel frontend (temporary, no custom domain)
CORS_ORIGINS=https://shirkat-gah-web.vercel.app,https://shirkat-gah.vercel.app
NEXT_PUBLIC_APP_URL=https://shirkat-gah-web.vercel.app

# AWS S3 (leave S3_ENDPOINT empty for native AWS)
AWS_REGION=ap-south-1
S3_REGION=ap-south-1
S3_BUCKET=shirkat-gah-production-assets
S3_PUBLIC_URL=
CDN_URL=https://your-cloudfront-domain.cloudfront.net

# AWS SES
AWS_SES_ENABLED=true
SES_FROM_EMAIL=noreply@shirkatgah.org

# Monitoring
SENTRY_DSN=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
