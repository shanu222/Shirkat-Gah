{
  "name": "shirkat-gah-platform",
  "private": true,
  "version": "1.0.0",
  "description": "Shirkat Gah Enterprise Digital Platform",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @shirkat-gah/web dev",
    "dev:api": "pnpm --filter @shirkat-gah/api dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @shirkat-gah/database generate",
    "db:migrate": "pnpm --filter @shirkat-gah/database migrate:dev",
    "db:push": "pnpm --filter @shirkat-gah/database push",
    "db:seed": "pnpm --filter @shirkat-gah/database seed",
    "db:studio": "pnpm --filter @shirkat-gah/database studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
