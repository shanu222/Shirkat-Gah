{
  "name": "shirkat-gah-platform",
  "private": true,
  "version": "1.0.0",
  "description": "Shirkat Gah Enterprise Digital Platform",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @shirkat-gah/web dev",
    "dev:api": "pnpm db:generate && turbo run build --filter=@shirkat-gah/database --filter=@shirkat-gah/shared && pnpm --filter @shirkat-gah/api dev",
    "build": "turbo run build",
    "build:production": "pnpm db:generate && turbo run build",
    "build:api": "pnpm db:generate && turbo run build --filter=@shirkat-gah/database --filter=@shirkat-gah/shared --filter=@shirkat-gah/api",
    "build:web": "turbo run build --filter=@shirkat-gah/web",
    "start": "pnpm start:pm2",
    "start:api": "node apps/api/dist/main.js",
    "start:prod": "NODE_ENV=production node apps/api/dist/main.js",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "deploy:ec2": "bash deploy/scripts/deployment.sh",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @shirkat-gah/database generate",
    "db:migrate": "pnpm --filter @shirkat-gah/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @shirkat-gah/database migrate:deploy",
    "db:push": "pnpm --filter @shirkat-gah/database push",
    "db:seed": "pnpm --filter @shirkat-gah/database seed",
    "db:studio": "pnpm --filter @shirkat-gah/database studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
