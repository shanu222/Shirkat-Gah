# =============================================================================
# SHIRKAT GAH — ENVIRONMENT CONFIGURATION
# Copy to .env and fill values. NEVER commit .env to git.
# =============================================================================

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
# development | staging | production

# ─── Database (AWS RDS in production) ────────────────────────────────────────
DATABASE_URL="postgresql://shirkat:shirkat_secret@localhost:5432/shirkat_gah?schema=public"

# ─── Redis (AWS ElastiCache in production) ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT Authentication ──────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-64-char-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── NextAuth (Vercel Frontend) ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-nextauth-secret-in-production"

# ─── API ─────────────────────────────────────────────────────────────────────
API_URL="http://localhost:4000"
API_PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"

# CORS — comma-separated Vercel URLs (production)
CORS_ORIGINS="http://localhost:3000,https://app.shirkatgah.org,https://shirkat-gah.vercel.app"

# ─── AWS (Production) ────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_SES_ENABLED=false

# S3 — leave S3_ENDPOINT empty in production (uses IAM role on ECS)
S3_ENDPOINT="http://localhost:9000"
S3_REGION=ap-south-1
S3_BUCKET=shirkat-gah
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL="http://localhost:9000/shirkat-gah"
CDN_URL=

# SES Email
SES_FROM_EMAIL=noreply@shirkatgah.org

# ─── Email (Development — MailHog) ───────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@shirkatgah.org

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Mapbox / GIS ────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Sentry Monitoring ───────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Shirkat Gah"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Vercel (set in Vercel dashboard for production) ─────────────────────────
# VERCEL_URL — auto-set by Vercel
# VERCEL_ENV — auto-set by Vercel
